# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Local dev:  http://localhost:54321  (from: npx supabase status)
# Production: https://<project-ref>.supabase.co  (from Supabase dashboard)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must match the JWT secret in your Supabase project settings → API → JWT secret
JWT_SECRET=your-jwt-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local dev:  http://localhost:5173
# Production: https://your-vercel-app.vercel.app  (or custom domain)
FRONTEND_URL=http://localhost:5173

# ─── Julia optimizer ──────────────────────────────────────────────────────────
# Local dev:  http://localhost:3002
# Production: https://boca-julia.fly.dev  (from: flyctl status)
JULIA_URL=http://localhost:3002

# ─── Email — Resend ───────────────────────────────────────────────────────────
# Create a free account at resend.com, verify your domain, generate an API key
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=no-reply@bocaboldisch.dk
